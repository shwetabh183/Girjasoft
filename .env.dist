# ============================================
# Girjasoft HRMS Environment Configuration
# ============================================

# Set "DEBUG=False" for production
DEBUG=True

# Get a secure secret key from https://djecrety.ir
SECRET_KEY=django-insecure-change-this-in-production

# Don't use "*" for ALLOWED_HOSTS in production
ALLOWED_HOSTS=localhost,127.0.0.1,*

# CSRF Trusted Origins (comma-separated, include https://)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Timezone
TIME_ZONE=Asia/Kolkata

# ============================================
# Database Configuration
# ============================================

# Option 1: DATABASE_URL (recommended for cloud deployments)
# DATABASE_URL=postgresql://user:password@localhost:5432/girjasoft_db

# Option 2: Individual database settings
DB_ENGINE=django.db.backends.postgresql
DB_NAME=girjasoft_db
DB_USER=girjasoft
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# Database initialization password (for first-time setup)
DB_INIT_PASSWORD=your_init_password

# ============================================
# GCP Storage Configuration (Optional)
# ============================================

# GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account.json"
# GS_BUCKET_NAME="your-gcp-bucket"
# DEFAULT_FILE_STORAGE="girjasoft.girjasoft_backends_gcp.PrivateMediaStorage"
# MEDIA_URL="https://storage.cloud.google.com/your-bucket/media"
# MEDIA_ROOT="https://storage.cloud.google.com/your-bucket/media"
# NAMESPACE="private"

# ============================================
# Supported DATABASE_URL Formats
# ============================================
# PostgreSQL: postgres[ql]?:// or p[g]?sql://
# MySQL: mysql:// or mysql2://
# SQLite: sqlite://
# Oracle: oracle://
# Microsoft SQL Server: mssql://
